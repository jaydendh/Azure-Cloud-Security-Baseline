# ---- Terraform ----

# Provider binaries + local plugin cache (this is what broke the push)
**/.terraform/*

# State files (may contain secrets — never commit)
*.tfstate
*.tfstate.*

# Plan output / crash logs
tfplan
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

